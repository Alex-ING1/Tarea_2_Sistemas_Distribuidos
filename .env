# ────────────────────────────────────────────────────────────────────────────
# CONFIGURACIÓN FASE 1: Consumer Básico
# ────────────────────────────────────────────────────────────────────────────

# Kafka
KAFKA_BROKER=kafka:9092
TOPIC_MAIN=queries
TOPIC_PROCESSED=queries-processed
TOPIC_DLQ=queries-dlq
KAFKA_GROUP_ID=consumer-group-1

# Generador de Tráfico
NUM_QUERIES=500
QUERY_RATE=0.05
SPIKE_ENABLED=false
SPIKE_MULTIPLIER=5
SPIKE_AT=200
SPIKE_DURATION=50

# Redis (Cache)
REDIS_HOST=redis
REDIS_PORT=6379

# CSV Path
CSV_PATH=/app/FiltradoFinal.csv

# Salida de Métricas
OUTPUT_FILE=/metricas/metricas.json
